{
  "name": "service-tradein-automower-tradetermform",
  "version": "1.0.0",
  "description": "Automower trade-in form with FastAPI backend, file uploads and admin UI",
  "exports": "./dist/main.js",
  "type": "module",
  "scripts": {
    "build": "pkgroll --sourcemap",
    "debug": "tsx --inspect-brk src/main.ts | pino-pretty",
    "dev": "tsx --watch src/main.ts | pino-pretty",
    "lint:fix": "xo --fix",
    "lint": "xo",
    "prepare": "husky",
    "semantic-release": "semantic-release",
    "start": "tsx --env-file=.env src/main.ts | pino-pretty",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "verify": "npm run lint && npm run type-check && npm run test"
  },
  "engines": {
    "node": "24.12.x",
    "npm": "11.x"
  },
  "author": "Emil A Karlsson",
  "license": "UNLICENSED",
  "dependencies": {
    "@husqvarna/healthz": "2.1.3",
    "@husqvarna/logging": "3.2.1",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "express": "5.2.1",
    "pino-http": "11.0.0",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.0",
    "@commitlint/config-conventional": "20.3.0",
    "@husqvarna/pino-pretty": "^1.1.31",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.3",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/express": "5.0.6",
    "@types/node": "25.0.3",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "4.0.16",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "9.1.7",
    "pino-pretty": "^13.1.3",
    "prettier": "3.7.4",
    "semantic-release": "25.0.2",
    "supertest": "7.2.2",
    "typescript": "5.9.3",
    "vitest": "4.0.16",
    "xo": "1.2.3"
  }
}
